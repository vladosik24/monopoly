<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg" android:padding="20dp">

    <TextView android:text="Налаштування гравців"
        android:textSize="20sp" android:textColor="@color/gold" android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:id="@+id/playerContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <Button android:id="@+id/btnPlay"
        android:text="▶ ГРАТИ"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/blue_ua"
        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>

    <Button android:id="@+id/btnBack"
        android:text="← Назад"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/card"
        android:textColor="@color/muted"/>
</LinearLayout>
