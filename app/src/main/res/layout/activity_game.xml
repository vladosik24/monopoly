<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:background="@color/card">
        <TextView android:text="🇺🇦 МОНОПОЛІЯ" android:textSize="16sp"
            android:textColor="@color/gold" android:textStyle="bold"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <TextView android:id="@+id/tvBank" android:text="Банк: ₴150,000"
            android:textSize="12sp" android:textColor="@color/green"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Board -->
    <GridLayout android:id="@+id/boardGrid"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="4dp"
        android:columnCount="11" android:rowCount="11"/>

    <!-- Log -->
    <TextView android:id="@+id/tvLog"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:textSize="11sp" android:textColor="@color/muted"
        android:background="@color/card" android:gravity="bottom"
        android:paddingBottom="4dp" android:paddingTop="4dp"
        android:ellipsize="end"/>

    <!-- Players bar -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/card" android:scrollbars="none">
        <LinearLayout android:id="@+id/playersBar"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="8dp"/>
    </HorizontalScrollView>

    <!-- Dice + Roll -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:background="@color/card">

        <TextView android:id="@+id/tvDie1" android:text="🎲"
            android:textSize="32sp" android:gravity="center"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#22FFFFFF"/>
        <TextView android:id="@+id/tvDie2" android:text="🎲"
            android:textSize="32sp" android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="#22FFFFFF"/>

        <Button android:id="@+id/btnRoll"
            android:text="🎲 КИНУТИ"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:backgroundTint="@color/blue_ua"
            android:textColor="@color/white" android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
